# frozen_string_literal: true

source "https://rubygems.org"

# Esta linha é essencial para o GitHub Actions saber o que instalar
gem "jekyll"

# Se você estiver usando um tema específico (ex: minima), adicione-o aqui
gem "minima", "~> 2.5"

# Plugins comuns que o GitHub Pages utiliza
group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.12"
  gem "jekyll-seo-tag"
end